# ============================================================
#  campro — Environment Variables
#  Copy this to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000

# ── Agora ─────────────────────────────────────────────────────
# Get these from https://console.agora.io → Your Project
AGORA_APP_ID=your_agora_app_id_here
# App Certificate is OPTIONAL in dev (no-token mode).
# Enable it in your Agora console and paste the certificate here for production.
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# ── Firebase (Client SDK — used by frontend) ──────────────────
# These come from your Firebase console → Project Settings → Your apps
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# ── Google Gemini AI ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase Admin SDK (Server-side — Firestore access) ───────
# Download from: Firebase console → Project Settings → Service accounts → Generate new private key
# Then paste the ENTIRE JSON as a single-line string (minified) here:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}
